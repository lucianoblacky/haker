# ── Stripe ────────────────────────────────────────────────
# Server-side secret key (never expose to the client)
STRIPE_SECRET_KEY=
# Publishable key, safe for client-side use
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (from the Stripe CLI or Dashboard webhook config)
STRIPE_WEBHOOK_SECRET=

# Apple Pay and Google Pay are enabled automatically through Stripe's
# Payment Request Button / Checkout once your Stripe account has them
# turned on under Settings -> Payment methods. No separate API keys
# are required — they ride on the Stripe keys above.

# ── PayPal ────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# "sandbox" (default) or "live"
PAYPAL_ENV=sandbox

# ── Site ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://peakmodo.com
